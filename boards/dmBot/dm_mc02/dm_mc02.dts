/dts-v1/;
#include <st/h7/stm32h723Xg.dtsi>
#include <st/h7/stm32h723vgtx-pinctrl.dtsi>

/ {
	model = "DaMiao MC02";
	compatible = "st";

	chosen {
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,dtcm = &dtcm;
		zephyr,canbus = &fdcan1;
	};

	/* 别名定义，方便应用层调用 */
	aliases {
		led0 = &ws2812;      /* WS2812 RGB LED */
		accel0 = &bmi088_accel;
		gyro0 = &bmi088_gyro;
		buzzer-pwm = &pwm_buzzer;
		watchdog0 = &iwdg1;
	};

};

&clk_hse {
	clock-frequency = <DT_FREQ_M(24)>;
	status = "okay";
};

&pll {
	div-m = <2>;
	mul-n = <40>;
	div-p = <1>;
	div-q = <2>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(480)>;
	/* Prescalers from IOC: HPRE=/2, PPRE1=/2, PPRE2=/2, PPRE3=/2, PPRE4=/2 */
	d1cpre = <2>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

&dma1 {
	status = "okay";
};

&dma2 {
	status = "okay";
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=41, TX=42 */
	dmas = <&dmamux1 41 0 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_HIGH)>,
		   <&dmamux1 42 1 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_HIGH)>;
	dma-names = "rx", "tx";
	status = "okay";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6 &usart2_de_pd4>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=43, TX=44 */
	dmas = <&dmamux1 43 2 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_MEDIUM)>,
		   <&dmamux1 44 3 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_MEDIUM)>;
	dma-names = "rx", "tx";

	/* RS485 模式配置 */
	rs485-rts-active-high;
	rs485-rx-during-tx;
	rs485-de-enable; /* 启用 DE 引脚自动控制 */

	status = "okay";
};

/*
 * 4. UART5 (From CubeMX & Internal)
 * CubeMX: PC12 (TX), PD2 (RX)
 * Note: PC12 is also SPI3_MOSI (Extension). Check for conflicts if using SPI3.
 */
&uart5 {
	pinctrl-0 = <&uart5_tx_pc12 &uart5_rx_pd2>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=65, TX=66 */
	dmas = <&dmamux1 65 6 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_LOW)>,
		   <&dmamux1 66 7 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_LOW)>;
	dma-names = "rx", "tx";
	status = "okay";
};

/*
 * 5. UART7 (Header Interface)
 * PDF Page 9: PE8 (TX), PE7 (RX)
 */
&uart7 {
	pinctrl-0 = <&uart7_tx_pe8 &uart7_rx_pe7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=79, TX=80 */
	/* 使用 DMA2 以分散负载 */
	dmas = <&dmamux1 79 0 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_LOW)>,
		   <&dmamux1 80 1 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_LOW)>;
	dma-names = "rx", "tx";
	status = "okay";
};

&uart8 {
	pinctrl-0 = <&uart8_tx_pe1 &uart8_rx_pe0>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=81, TX=82 */
	dmas = <&dmamux1 81 2 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_LOW)>,
		   <&dmamux1 82 3 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_LOW)>;
	dma-names = "rx", "tx";
	status = "okay";
};

&uart9 {
	pinctrl-0 = <&uart9_tx_pd15 &uart9_rx_pd14>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=115, TX=116 */
	dmas = <&dmamux1 115 4 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_LOW)>,
		   <&dmamux1 116 5 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_LOW)>;
	dma-names = "rx", "tx";
	status = "okay";
};

&uart10 {
	pinctrl-0 = <&uart10_tx_pe3 &uart10_rx_pe2>;
	pinctrl-names = "default";
	current-speed = <115200>;
	/* DMAMUX Req: RX=117, TX=118 */
	dmas = <&dmamux1 117 6 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_LOW)>,
		   <&dmamux1 118 7 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_LOW)>;
	dma-names = "rx", "tx";
	status = "okay";
};

&fdcan1 {
	pinctrl-0 = <&fdcan1_rx_pd0 &fdcan1_tx_pd1>;
	pinctrl-names = "default";
	bus-speed = <1000000>;
	bus-speed-data = <5000000>;
	status = "okay";
};

&fdcan2 {
	pinctrl-0 = <&fdcan2_rx_pb5 &fdcan2_tx_pb6>;
	pinctrl-names = "default";
	bus-speed = <1000000>;
	bus-speed-data = <5000000>;
	status = "okay";
};

&fdcan3 {
	pinctrl-0 = <&fdcan3_rx_pd12 &fdcan3_tx_pd13>;
	pinctrl-names = "default";
	bus-speed = <1000000>;
	bus-speed-data = <5000000>;
	status = "okay";
};

&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_miso_pc2 &spi2_mosi_pc1>;
	pinctrl-names = "default";
	status = "okay";

	/* CS 引脚: Accel=PC0, Gyro=PC3 */
	cs-gpios = <&gpioc 0 GPIO_ACTIVE_LOW>, <&gpioc 3 GPIO_ACTIVE_LOW>;

	bmi088_accel: bmi08x_accel@0 {
		compatible = "bosch,bmi08x-accel";
		reg = <0>;
		spi-max-frequency = <10000000>;
		/* INT1 连接到 PE10 */
		int-gpios = <&gpioe 10 GPIO_ACTIVE_HIGH>;
	};

	bmi088_gyro: bmi08x_gyro@1 {
		compatible = "bosch,bmi08x-gyro";
		reg = <1>;
		spi-max-frequency = <10000000>;
		/* INT3 连接到 PE12 */
		int-gpios = <&gpioe 12 GPIO_ACTIVE_HIGH>;
	};
};

/* WS2812 LED - 使用 SPI6 MOSI (PA7) 模拟驱动 */
&spi6 {
	pinctrl-0 = <&spi6_mosi_pa7>; /* 仅需 MOSI */
	pinctrl-names = "default";
	status = "okay";

	ws2812: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		spi-max-frequency = <4000000>; /* WS2812 时序要求 */
		chain-length = <1>; /* 板载只有 1 颗灯 */
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN
						 LED_COLOR_ID_RED
						 LED_COLOR_ID_BLUE>;
	};
};

&timers12 {
	status = "okay";
	st,prescaler = <23>;

	pwm12: pwm {
		status = "okay";
		pinctrl-0 = <&tim12_ch2_pb15>;
		pinctrl-names = "default";
	};
};

&timers3 {
	status = "okay";
	st,prescaler = <23>;

	pwm3: pwm {
		status = "okay";
		pinctrl-0 = <&tim3_ch4_pb1>;
		pinctrl-names = "default";
	};
};

/ {
	pwm_heater: pwm-heater {
		compatible = "pwm-heater";
		pwms = <&pwm3 1 PWM_USEC(100) PWM_POLARITY_NORMAL>;
		temp-sensor = <&bmi088_accel>;
		temp-channel = <12>; /* SENSOR_CHAN_DIE_TEMP */
		status = "okay";
	};
};

/ {
	pwm_buzzer: pwm-buzzer {
		compatible = "pwm-buzzer";
		pwms = <&pwm12 2 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
		status = "okay";
	};
};

/* QSPI Flash (W25Q64) - OCTOSPI1 Port 1
 * 引脚: CS=PE11, CLK=PB2, IO0=PD11, IO1=PB0, IO2=PA3, IO3=PA1
 */
&octospi1 {
	pinctrl-0 = <&octospim_p1_clk_pb2 &octospim_p1_ncs_pe11
				 &octospim_p1_io0_pd11 &octospim_p1_io1_pb0
				 &octospim_p1_io2_pa3 &octospim_p1_io3_pa1>;
	pinctrl-names = "default";
	status = "okay";

	w25q64: w25q64jv@0 {
		compatible = "winbond,w25q64jv", "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <80000000>;
		size = <0x800000>; /* 8MB */
		jedec-id = [ef 40 17];
	};
};

/* USB OTG */
&usbotg_hs {
	/* H723 usually has HS core but often used with FS PHY on PA11/PA12 */
	pinctrl-0 = <&usb_otg_hs_dm_pa11 &usb_otg_hs_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

&iwdg1 {
	status = "okay";
};

&rng {
	status = "okay";
};
